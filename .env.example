# Optional Docker Compose build-time override for the frontend.
NEXT_PUBLIC_GATEWAY_URL=http://localhost

# Local development falls back to guest/guest if these are omitted.
# Production compose requires non-default values.
RABBITMQ_DEFAULT_USER=replace_with_rabbitmq_user
RABBITMQ_DEFAULT_PASS=replace_with_rabbitmq_password
GATEWAY_HTTP_PORT=80
GATEWAY_HTTPS_PORT=443

# Required by docker-compose.prod.yml. URL-encode passwords if they contain
# URI-reserved characters such as @, :, /, ?, #, [, ], or &.
MONGO_ROOT_USERNAME=replace_with_mongo_root_user
MONGO_ROOT_PASSWORD=replace_with_mongo_root_password
REDIS_PASSWORD=replace_with_redis_password
NGINX_TLS_CERT_PATH=./secrets/nginx/tls.crt
NGINX_TLS_KEY_PATH=./secrets/nginx/tls.key
