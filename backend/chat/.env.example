PORT=5002
MONGO_URI=mongodb://localhost:27017/chat_app
MONGO_DB_NAME=chat_chat_service
REDIS_URL=rediss://default:replace_with_redis_password@your-redis-host:6379
CALL_RING_TIMEOUT_SECONDS=30

# Generate this value with: node scripts/generate-keys.mjs
JWT_PUBLIC_KEY=replace_with_generated_public_key_single_line
JWT_ISSUER=chat-app-auth
JWT_AUDIENCE=chat-app-clients

Rabbitmq_Host=localhost
Rabbitmq_Username=guest
Rabbitmq_Password=guest

CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret